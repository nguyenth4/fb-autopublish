# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_TLS=true  # uncomment for managed Redis with TLS

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://yourdomain.com
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# ── AES-256 Encryption ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: rotating this key makes all stored tokens unreadable — backup externally
ENCRYPTION_KEY=

# ── Facebook App ──────────────────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Storage (AWS S3 or MinIO) ─────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=fb-autopublish-media
# MinIO only (omit for AWS S3):
# S3_ENDPOINT=https://minio.yourdomain.com
# CDN_BASE_URL=https://cdn.yourdomain.com
